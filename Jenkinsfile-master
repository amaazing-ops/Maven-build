pipeline {
  agent any

tools {
  jdk 'Java8'
  maven 'Maven3'
}

stages {
  stage ('Git checkout') {
    steps {
        git branch: 'main', url: 'https://github.com/amaazing-ops/Maven-build.git'
       }
     }
   stage ('Maven Build') {
    steps {
        sh 'mvn clean package'
       }
     }
   }
}
